{
  "expo": {
    "name": "Clearway",
    "slug": "clearway",
    "version": "1.0.0",
    "scheme": "clearway",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rdh36.clearway"
    },
    "android": {
      "package": "com.rdh36.clearway",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1B1F"
      }
    },
    "plugins": [
      "./plugins/withTransparentNavBar",
      "./plugins/withWidgetFitXY",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#0E1B1F"
        }
      ],
      "expo-audio",
      "expo-notifications",
      [
        "react-native-android-widget",
        {
          "fonts": [
            "./assets/fonts/BricolageGrotesque_700Bold.ttf",
            "./assets/fonts/HankenGrotesk_400Regular.ttf",
            "./assets/fonts/HankenGrotesk_600SemiBold.ttf",
            "./assets/fonts/GeistMono_500Medium.ttf"
          ],
          "widgets": [
            {
              "name": "Clearway",
              "label": "Clearway",
              "description": "Days clear, money saved, next milestone",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 3600000
            },
            {
              "name": "ClearwaySmall",
              "label": "Clearway · Days",
              "description": "Your days clear at a glance",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 3600000
            }
          ]
        }
      ],
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ff7dba4-8aaf-4877-a266-7b5051edc9e3"
      }
    },
    "owner": "rdh36"
  }
}
