{
  "expo": {
    "name": "Clearway",
    "slug": "clearway",
    "version": "1.0.0",
    "scheme": "clearway",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rdh36.clearway"
    },
    "android": {
      "package": "com.rdh36.clearway",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1B1F"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#0E1B1F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ff7dba4-8aaf-4877-a266-7b5051edc9e3"
      }
    },
    "owner": "rdh36"
  }
}
